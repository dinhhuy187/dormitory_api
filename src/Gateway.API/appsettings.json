{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "api/auth/{**catch-all}"
        }
      },
      "booking-route": {
        "ClusterId": "booking-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "api/bookings/{**catch-all}"
        }
      },
      "bookingopenapi-route": {
        "ClusterId": "booking-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "api/bookings/openapi/v1.json"
        }
      },
      "room-route": {
        "ClusterId": "room-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "api/rooms/{**catch-all}"
        }
      },
      "roomopenapi-route": {
        "ClusterId": "room-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "api/rooms/openapi/v1.json"
        }
      },
      "profile-route": {
        "ClusterId": "profile-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "api/profile/{**catch-all}"
        }
      },
      "profileapi-route": {
        "ClusterId": "profile-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "api/profile/openapi/v1.json"
        }
      },
      "community-route": {
        "ClusterId": "community-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "api/community/{**catch-all}"
        }
      },
      "communitypost-route": {
        "ClusterId": "community-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "api/posts/{**catch-all}"
        }
      },
      "communityopenapi-route": {
        "ClusterId": "community-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "api/community/openapi/v1.json"
        }
      },
      "incident-route": {
        "ClusterId": "incident-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "api/incidents/{**catch-all}"
        }
      },
      "incidentapi-route": {
        "ClusterId": "incident-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "api/incidents/openapi/v1.json"
        }
      },
      "chat-route": {
        "ClusterId": "chat-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "api/conversations/{**catch-all}"
        }
      },
      "chatopenapi-route": {
        "ClusterId": "chat-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "api/conversations/openapi/v1.json"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-destination": {
            "Address": "http://identity-api/"
          }
        }
      },
      "room-cluster": {
        "Destinations": {
          "room-destination": {
            "Address": "http://room-api/"
          }
        }
      },
      "profile-cluster": {
        "Destinations": {
          "profile-destination": {
            "Address": "http://profile-api/"
          }
        }
      },
      "booking-cluster": {
        "Destinations": {
          "booking-destination": {
            "Address": "http://booking-api/"
          }
        }
      },
      "community-cluster": {
        "Destinations": {
          "community-destination": {
            "Address": "http://community-api/"
          }
        }
      },
      "incident-cluster": {
        "Destinations": {
          "incident-destination": {
            "Address": "http://incident-api/"
          }
        }
      },
      "chat-cluster": {
        "Destinations": {
          "chat-destination": {
            "Address": "http://chat-api/"
          }
        }
      }
    }
  }
}
